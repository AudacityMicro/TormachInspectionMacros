o<initialize_inspection> sub

#<_dont_change_WCS> = 0 (change the WCS by default)
#<_featureNumber> = 0 (reset feature counter)
#<_componentNumber> = 0 (reset component counter)
#<_inspection_end_x> = 0 (set by the post before the program-end macro)
#<_inspection_end_y> = 0 (set by the post before the program-end macro)
#<_inspection_end_change_tool> = 0 (program-end tool change disabled by default)
#<_inspection_end_tool_number> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_enabled> = 0 (program-end table washdown disabled by default)
#<_inspection_washdown_x_min> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_x_max> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_y_min> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_y_max> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_z> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_passes> = 0 (set by the post before the program-end macro)
#<_inspection_washdown_feed> = 0 (set by the post before the program-end macro)
#<_inspection_archive_results> = 0 (archive only when results were generated)

o<initialize_inspection> endsub
